# Copy to oauth-secrets.local.env and fill in values (never commit the real file).
# Then run: .\scripts\push-oauth-secrets.ps1

OAUTH_SLACK_CLIENT_ID=
OAUTH_SLACK_CLIENT_SECRET=

# Google: optional — use the SAME Client ID/secret as Supabase Auth → Providers → Google
# (refreshes agent tokens; Connect flow uses Supabase Auth, not oauth-start)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

OAUTH_DISCORD_CLIENT_ID=
OAUTH_DISCORD_CLIENT_SECRET=

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

OAUTH_NOTION_CLIENT_ID=
OAUTH_NOTION_CLIENT_SECRET=

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
